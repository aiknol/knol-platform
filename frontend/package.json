{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "web",
    "admin",
    "cloud",
    "demo"
  ],
  "scripts": {
    "build:web": "npm run build -w web",
    "build:admin": "npm run build -w admin",
    "build:app": "npm run build -w app",
    "build:demo": "npm run build -w demo",
    "build:all": "npm run build:web && npm run build:admin && npm run build:app && npm run build:demo",
    "dev:web": "npm run dev -w web",
    "dev:admin": "npm run dev -w admin",
    "dev:app": "npm run dev -w app",
    "dev:demo": "npm run dev -w demo",
    "lint:web": "npm run lint -w web",
    "lint:admin": "npm run lint -w admin",
    "lint:app": "npm run lint -w app",
    "test:app": "npm run test -w app",
    "smoke": "../scripts/frontend-smoke.sh"
  }
}
