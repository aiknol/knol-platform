# Knol OSS example environment
# Copy to .env and adjust values for your deployment.

# Core infrastructure
DATABASE_URL=postgresql://memory:memory_dev@localhost:5432/memory
NATS_URL=nats://localhost:4222
REDIS_URL=redis://localhost:6379

# Service ports / routing (optional overrides)
GATEWAY_PORT=8080
WRITE_SERVICE_URL=http://localhost:8081
RETRIEVE_SERVICE_URL=http://localhost:8082
ADMIN_SERVICE_URL=http://localhost:8084
GATEWAY_CORS_ORIGINS=http://localhost:3005

# LLM defaults (provider can also be configured in system_config)
LLM_PROVIDER=anthropic
LLM_API_KEY=replace-me
ANTHROPIC_API_KEY=replace-me
OPENAI_API_KEY=replace-me
GEMINI_API_KEY=replace-me
ANTHROPIC_MODEL=claude-3-haiku-20240307
OPENAI_MODEL=gpt-4o-mini
GEMINI_MODEL=gemini-1.5-flash

# Optional webhook secret encryption (base64-encoded 32-byte key)
WEBHOOK_ENCRYPTION_KEY=replace-with-base64-32-byte-key
ADMIN_ENCRYPTION_KEY=replace-with-base64-32-byte-key
