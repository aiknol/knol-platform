# =============================================================================
# Knol — Environment Configuration (Minimal)
# =============================================================================
# Copy to .env and fill in the values.
#
# This file contains ONLY infrastructure and secrets that must be set before
# the database is available. Everything else (ports, LLM models, rate limits,
# CORS, MINIO, marketing credentials, etc.) is managed through the Admin Panel
# at /admin/config and stored in the system_config / system_credentials tables.
# =============================================================================

# ---------- Infrastructure (required before DB pool) ----------
DATABASE_URL=postgres://memorylayer:memorylayer@localhost:5432/memorylayer
REDIS_URL=redis://localhost:6379
NATS_URL=nats://localhost:4222

# ---------- Admin Secrets ----------
ADMIN_JWT_SECRET=replace-with-random-32-plus-char-secret
ADMIN_ENCRYPTION_KEY=replace-with-base64-encoded-32-byte-key
ADMIN_INITIAL_PASSWORD=replace-with-strong-password

# ---------- Logging ----------
RUST_LOG=info,memorylayer=debug
