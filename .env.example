# =============================================================================
# Knol — Environment Configuration (Minimal)
# =============================================================================
# Copy to .env and fill in the values.
#
# This file contains ONLY infrastructure and secrets that must be set before
# the database is available. Everything else (ports, LLM models, rate limits,
# CORS, MINIO, marketing credentials, etc.) is managed through the Admin Panel
# at /admin/config and stored in the system_config / system_credentials tables.
# =============================================================================

# ---------- Infrastructure (required before DB pool) ----------
DATABASE_URL=postgres://memorylayer:memorylayer@localhost:5432/memorylayer
REDIS_URL=redis://localhost:6379
NATS_URL=nats://localhost:4222

# ---------- Admin Secrets ----------
ADMIN_JWT_SECRET=replace-with-random-32-plus-char-secret
ADMIN_ENCRYPTION_KEY=replace-with-base64-encoded-32-byte-key
ADMIN_INITIAL_PASSWORD=replace-with-strong-password
INTERNAL_SERVICE_SECRET=replace-with-random-internal-service-secret

# ---------- Admin Options (optional) ----------
# ADMIN_INITIAL_EMAIL=admin@yourdomain.com          # Default: admin@aiknol.com
# ADMIN_SECURE_COOKIES=true                          # Set to false for local dev (no HTTPS)
# ADMIN_CORS_ORIGIN=http://localhost:3005,http://localhost:3006,http://localhost:3007,http://localhost:3008
# MARKETING_SERVICE_URL=http://marketing:8088        # Internal URL to marketing service

# ---------- Frontend (set at build time for Cloudflare Pages) ----------
# Base domain strategy (recommended):
# Local ports:
# NEXT_PUBLIC_BASE_DOMAIN=localhost
# NEXT_PUBLIC_URL_SCHEME=http
# NEXT_PUBLIC_SITE_URL=http://localhost:3005
# NEXT_PUBLIC_APP_HOST=localhost
# NEXT_PUBLIC_APP_PORT=3007
# NEXT_PUBLIC_DEMO_HOST=localhost
# NEXT_PUBLIC_DEMO_PORT=3008
# NEXT_PUBLIC_ADMIN_API_HOST=localhost
# NEXT_PUBLIC_ADMIN_API_PORT=3001
#
# Production subdomains:
# NEXT_PUBLIC_BASE_DOMAIN=aiknol.com
# NEXT_PUBLIC_URL_SCHEME=https
# NEXT_PUBLIC_SITE_URL=https://aiknol.com
# NEXT_PUBLIC_APP_HOST=cloud.aiknol.com
# NEXT_PUBLIC_DEMO_HOST=demo.aiknol.com
# NEXT_PUBLIC_ADMIN_API_HOST=admin.aiknol.com
#
# Optional explicit overrides (take precedence over base-domain settings):
# NEXT_PUBLIC_ADMIN_API_URL=https://admin.yourdomain.com
# NEXT_PUBLIC_APP_API_URL=https://admin.yourdomain.com
# NEXT_PUBLIC_APP_URL=https://cloud.yourdomain.com/signup/
# NEXT_PUBLIC_DEMO_URL=https://demo.yourdomain.com/
# APP_WEBSITE_MODE=true  # Optional: run web root as tenant app login

# ---------- Logging ----------
RUST_LOG=info,memorylayer=debug
