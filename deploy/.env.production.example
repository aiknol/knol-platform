# =============================================================================
# Knol — Production Environment Template
# =============================================================================
# Copy this file to .env.production and fill in real values.
#
# This file intentionally contains only infrastructure + bootstrap secrets.
# Runtime product settings should be managed via the Admin Panel.
# =============================================================================

# ---------- Infrastructure ----------
# Use managed Postgres + Redis in production (recommended).
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require
REDIS_URL=rediss://default:PASSWORD@HOST:PORT

# Internal Docker network URL for NATS
NATS_URL=nats://nats:4222

# ---------- Admin bootstrap secrets ----------
# Generate with: openssl rand -base64 32
ADMIN_JWT_SECRET=replace-with-random-32-plus-char-secret
ADMIN_ENCRYPTION_KEY=replace-with-base64-encoded-32-byte-key

# Initial admin password for first login (rotate after setup)
ADMIN_INITIAL_PASSWORD=replace-with-strong-password

# ---------- Domains ----------
API_DOMAIN=api.aiknol.com
ADMIN_DOMAIN=admin.aiknol.com
CORS_ALLOW_ORIGIN=https://aiknol.com

# ---------- Object storage (MinIO in this starter compose) ----------
MINIO_ACCESS_KEY=replace-with-random-access-key
MINIO_SECRET_KEY=replace-with-random-secret-key

# ---------- Optional ----------
IMAGE_TAG=latest
RUST_LOG=info,memorylayer=debug
