# =============================================================================
# Knol — Caddy Reverse Proxy Configuration
# Automatic HTTPS via Let's Encrypt, HTTP/2 + HTTP/3
# =============================================================================

# API — api.aiknol.com
{$API_DOMAIN:api.aiknol.com} {
	# Gateway is the single entry point for all API traffic
	reverse_proxy gateway:8080 {
		health_uri /health
		health_interval 15s
	}

	# Security headers
	header {
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		X-XSS-Protection "1; mode=block"
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		-Server
	}

	# Note: For rate limiting, use the gateway service's built-in
	# rate limiter (tower-http) or add caddy-rate-limit plugin:
	# https://github.com/mholt/caddy-ratelimit

	# Request logging
	log {
		output stdout
		format json
		level INFO
	}

	# CORS is handled in the gateway service so per-origin logic stays centralized.
}

# Admin dashboard — admin.aiknol.com (enterprise)
{$ADMIN_DOMAIN:admin.aiknol.com} {
	# Human-friendly landing for the admin subdomain.
	@root path /
	redir @root https://app.aiknol.com/admin/ 308

	reverse_proxy admin:8084 {
		health_uri /health
		health_interval 15s
	}

	header {
		X-Content-Type-Options nosniff
		X-Frame-Options SAMEORIGIN
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		-Server
	}

	log {
		output stdout
		format json
	}
}

# Internal service routes — not publicly exposed, but available on
# the internal network for service-to-service communication.
# Caddy only proxies the gateway and admin externally.

# MinIO console — optional, only enable for debugging
# Uncomment to expose at minio.aiknol.com:
#
# {$MINIO_DOMAIN:minio.aiknol.com} {
# 	reverse_proxy minio:9001
# }

# NATS monitoring — optional, only enable for debugging
# Uncomment to expose at nats.aiknol.com:
#
# {$NATS_DOMAIN:nats.aiknol.com} {
# 	reverse_proxy nats:8222
# }
