# =============================================================================
# Knol — Caddy Reverse Proxy Configuration
# Automatic HTTPS via Let's Encrypt, HTTP/2 + HTTP/3
# =============================================================================

# API — api.aiknol.com
{$API_DOMAIN:api.aiknol.com} {
	# API routing:
	# - /app/*   -> tenant service (cloud tenant auth/workspace APIs)
	# - /admin/* -> admin service (admin control plane APIs)
	# - all else -> gateway (OSS/public memory APIs)
	route {
		@tenant_api path /app/*
		handle @tenant_api {
			reverse_proxy tenant:8085 {
				health_uri /health
				health_interval 15s
			}
		}

		@admin_api path /admin/*
		handle @admin_api {
			reverse_proxy admin:8084 {
				health_uri /health
				health_interval 15s
			}
		}

		handle {
			reverse_proxy gateway:8080 {
				health_uri /health
				health_interval 15s
			}
		}
	}

	# Security headers
	header {
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		X-XSS-Protection "1; mode=block"
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		-Server
	}

	# Note: For rate limiting, use the gateway service's built-in
	# rate limiter (tower-http) or add caddy-rate-limit plugin:
	# https://github.com/mholt/caddy-ratelimit

	# Request logging
	log {
		output stdout
		format json
		level INFO
	}

	# CORS is handled in the gateway service so per-origin logic stays centralized.
}

# Cloud Frontend — cloud.aiknol.com (static export)
{$CLOUD_DOMAIN:cloud.aiknol.com} {
	root * /srv/cloud
	file_server
	try_files {path} {path}/ /index.html

	# Security headers
	header {
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		X-XSS-Protection "1; mode=block"
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self' {$API_DOMAIN:api.aiknol.com} https://checkout.stripe.com; frame-src https://js.stripe.com; font-src 'self'"
		Referrer-Policy strict-origin-when-cross-origin
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
		-Server
	}

	log {
		output stdout
		format json
		level INFO
	}
}

# Internal service routes — not publicly exposed, but available on
# the internal network for service-to-service communication.
# Caddy only exposes the API domain externally.

# MinIO console — optional, only enable for debugging
# Uncomment to expose at minio.aiknol.com:
#
# {$MINIO_DOMAIN:minio.aiknol.com} {
# 	reverse_proxy minio:9001
# }

# NATS monitoring — optional, only enable for debugging
# Uncomment to expose at nats.aiknol.com:
#
# {$NATS_DOMAIN:nats.aiknol.com} {
# 	reverse_proxy nats:8222
# }
